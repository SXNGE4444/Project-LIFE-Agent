{
  "manifest_version": 3,
  "name": "Project LIFE Agent — Legibility Engine",
  "version": "0.1.0",
  "description": "Expose hidden corporate agendas. See what websites are really doing to your attention, data, and autonomy.",
  "author": "Project LIFE Agent Contributors",
  "homepage_url": "https://github.com/SXNGE4444/Project-LIFE-Agent",
  "permissions": [
    "storage",
    "activeTab",
    "webNavigation"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "exclude_matches": [
        "*://*.google.com/recaptcha/*",
        "*://*.hcaptcha.com/*",
        "*://*.cloudflare.com/cdn-cgi/*",
        "*://accounts.google.com/*",
        "*://login.*/*",
        "*://signin.*/*",
        "*://*.zoom.us/*",
        "*://teams.microsoft.com/*",
        "*://meet.google.com/*"
      ],
      "js": ["lib/pattern-detector.js", "lib/tracker-analyzer.js", "content-script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["config/*", "lib/*"],
      "matches": ["https://*/*", "http://*/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "LIFE Agent — View Harm Report"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "tracker_rules",
        "enabled": false,
        "path": "rules/tracker_rules.json"
      }
    ]
  }
}
